{
  "name": "NovaPanel Minecraft Server",
  "image": "mcr.microsoft.com/devcontainers/java:1-21-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "forwardPorts": [
    25565,
    25575,
    19132,
    8081
  ],
  "portsAttributes": {
    "8081": {
      "label": "Eaglercraft WebSocket"
    },
    "19132": {
      "label": "Minecraft Bedrock"
    },
    "25565": {
      "label": "Minecraft Java",
      "onAutoForward": "notify"
    },
    "25575": {
      "label": "RCON"
    }
  },
  "postCreateCommand": "chmod +x .novapanel/bootstrap.sh && .novapanel/bootstrap.sh",
  "postStartCommand": "nohup node agent.js > agent.log 2>&1 &",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack"
      ]
    }
  },
  "hostRequirements": {
    "cpus": 2,
    "memory": "4gb",
    "storage": "32gb"
  },
  "containerEnv": {
    "NOVAPANEL_SUPABASE_URL": "https://yooqmcdouubgusezozas.supabase.co",
    "NOVAPANEL_AGENT_TOKEN": "019d3f772221d8811c174e7c27d8ff4acd8d6d221b7c69d1317b9da72ba76956",
    "NOVAPANEL_KIND": "java",
    "NOVAPANEL_JAVA_CMD": "java -Xms2G -Xmx4G -jar server.jar nogui"
  }
}